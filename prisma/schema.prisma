// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tickets {
  id                 Int        @id @default(autoincrement())
  ticket             Int        @unique
  distributor        String
  state              String
  inverterModel      String
  serialNumber       String
  systemType         SystemType 
  error              String?
  priority           Priority
  workflow           String?
  daysOpen           Int        @default(0)
  warrantyApprovedAt DateTime?
  warrantyDeniedAt   DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

enum SystemType {
  ON_GRID
  OFF_GRID
  ZERO_GRID
  MICRO
  HYBRID
  CHARGER
  BATTERY
  DATALOGGER
  GENERAL
}

enum Priority {
  ON_TIME
  LOW_PRIORITY
  MODERATE
  HIGH_PRIORITY
  CRITICAL
  FINISHED
  ERROR_DATE_NOT_FOUND
}
