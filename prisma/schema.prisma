// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WarrantyTickets {
  id                 Int        @id @default(autoincrement())
  ticket             Int        @unique
  serialNumber       String
  warrantyApprovedAt DateTime?
  warrantyDeniedAt   DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model InverterModel {
  id       Int          @id @default(autoincrement())
  model    String  @unique
  line     String?
  type     String
  gridType String?
}

model Agents {
  id         String   @id  // ID que vem do Movidesk
  name       String
  email      String?
  syncedAt   DateTime @default(now()) @map("synced_at")

  responses  TicketResponse[]

}

model TicketResponse {
  id          Int      @id @default(autoincrement())
  ticketId    String   @map("ticket_id")
  agentId     String   @map("agent_id")
  respondedAt DateTime @default(now()) @map("responded_at")

  agent       Agents    @relation(fields: [agentId], references: [id])

}